generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          String    @default("USER") // ADMIN, USER, SALES_REP, SALES_MANAGER
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  repClients    Client[]      @relation("RepClients")
  repOrders     ClientOrder[] @relation("RepOrders")
  webOrders     WebOrder[]
}

model SiteSettings {
  id                String   @id @default(cuid())
  siteNameAr        String   @default("مصنع السلام للزيوت النباتية")
  siteNameEn        String   @default("Elsalam Vegetable Oils Factory")
  siteDescriptionAr String?
  siteDescriptionEn String?
  contactEmail      String?
  contactPhone      String?
  addressAr         String?
  addressEn         String?
  facebookUrl       String?
  twitterUrl        String?
  instagramUrl      String?
  linkedinUrl       String?
  smtpHost          String?
  smtpPort          Int?     @default(587)
  smtpUser          String?
  smtpPass          String?
  smtpFrom          String?
  smtpFromName      String?
  smtpSecure        String?  @default("tls")

  imapHost          String?
  imapPort          Int?     @default(993)
  imapSecure        String?  @default("tls") // none, ssl, tls
  imapUser          String?
  imapPass          String?

  logoUrl           String?
  invoiceNotesAr    String?
  invoiceNotesEn    String?
  invoiceShowLogo   Boolean  @default(true)
  invoiceLogoUrl    String?
  invoiceLogoSize   Int?     @default(64)
  invoiceColor      String?  @default("#15803d")
  invoiceSubtitle   String?  @default("Industrial High-Quality Oils & Fats")
  invoiceWebsiteUrl String?  @default("www.elsalamoils.com")
  invoiceCompanyDetails String?

  googleAnalyticsId String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model PageContent {
  id        String   @id @default(cuid())
  pageSlug  String   @unique
  content   String   // JSON string containing sections data
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PageContentHistory {
  id        String   @id @default(cuid())
  pageSlug  String
  content   String
  savedAt   DateTime @default(now())
  label     String   @default("")

  @@index([pageSlug, savedAt])
}

model Category {
  id        Int       @id @default(autoincrement())
  name_ar   String
  name_en   String
  slug      String    @unique
  imageUrl  String?   @db.Text
  sortOrder Int       @default(0)
  products  Product[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Product {
  id                   Int       @id @default(autoincrement())
  slug                 String    @unique
  name_ar              String
  name_en              String
  short_description_ar String?
  short_description_en String?
  description_ar       String?
  description_en       String?
  long_description_ar  String?
  long_description_en  String?
  featured_image       String?
  price                Float?
  price_unit_ar        String?
  price_unit_en        String?
  is_exportable        Boolean   @default(false)
  is_featured          Boolean   @default(false)
  icon                 String?
  gradient_from        String?
  gradient_to          String?
  categoryId           Int?
  stock                Int       @default(100)
  activePromotionId    Int?      @unique

  category       Category?       @relation(fields: [categoryId], references: [id])
  features       ProductFeature[]
  certifications ProductCertification[]
  pdf_datasheet  String?
  meta_title     String?
  meta_description String?
  specs          ProductSpec[]
  technical_specs TechnicalSpec[]
  images         ProductImage[]
  packagings     ProductPackaging[]
  promotions     Promotion[]
  orderItems     OrderItem[]
  webOrderItems  WebOrderItem[]

  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
}

model ProductFeature {
  id        Int     @id @default(autoincrement())
  productId Int
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  feature_ar String
  feature_en String
}

model ProductCertification {
  id        Int     @id @default(autoincrement())
  productId Int
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  name      String
}

model ProductSpec {
  id        Int     @id @default(autoincrement())
  productId Int
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  label_ar  String
  label_en  String
  value_ar  String
  value_en  String
}

model TechnicalSpec {
  id          Int     @id @default(autoincrement())
  productId   Int
  product     Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  property_ar String
  property_en String
  value_ar    String
  value_en    String
  unit_ar     String?
  unit_en     String?
}

model ProductImage {
  id        Int     @id @default(autoincrement())
  productId Int
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  url       String
  alt_text  String?
}

model ProductPackaging {
  id        Int     @id @default(autoincrement())
  productId Int
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  size_ar   String
  size_en   String
  price     Float?
}

model Promotion {
  id             Int       @id @default(autoincrement())
  productId      Int?
  product        Product?  @relation(fields: [productId], references: [id], onDelete: Cascade)
  title_ar       String
  title_en       String
  description_ar String?
  description_en String?
  discount_type  String    // e.g., 'percentage', 'fixed'
  discount_value Float
  original_price Float?
  promo_price    Float?
  badge_ar       String?
  badge_en       String?
  featured_image String?
  starts_at      DateTime?
  ends_at        DateTime
    isActive       Boolean   @default(true)

  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model News {
  id               Int       @id @default(autoincrement())
  slug             String    @unique
  title_ar         String
  title_en         String
  excerpt_ar       String?
  excerpt_en       String?
  content_ar       String?
  content_en       String?
  category         String    @default("news")
  tags             String?
  featured_image   String?
  image_alt        String?
  meta_title       String?
  meta_description String?
  is_featured      Boolean   @default(false)
  is_published     Boolean   @default(false)
  published_at     DateTime?
  scheduled_at     DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
}

model Message {
  id          Int       @id @default(autoincrement())
  name        String
  email       String
  phone       String?
  company     String?
  subject     String
  body        String
  type        String    @default("inquiry") // inquiry, complaint, suggestion, order, partnership
  status      String    @default("new")     // new, read, replied, archived
  priority    String    @default("normal")  // low, normal, high, urgent
  reply       String?
  repliedAt   DateTime?
  repliedBy   String?
  notes       String?
  isStarred   Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Client {
  id             Int      @id @default(autoincrement())
  name           String
  company        String?
  industry       String?
  storeType      String?  // سوبرماركت، محل غذائي، عطارة
  mainPhone      String?
  secondaryPhone String?
  storeImage     String?
  lat            Float?
  lng            Float?
  locationUrl    String?
  notes          String?
  status         String   @default("LEAD")
  creditLimit    Float    @default(0)
  outstandingBalance Float @default(0)
  repId          String?
  rep            User?    @relation("RepClients", fields: [repId], references: [id])
  contacts       ClientContact[]
  orders         ClientOrder[]
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model ClientContact {
  id          Int      @id @default(autoincrement())
  clientId    Int
  client      Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  personName  String?
  department  String   // e.g., "المبيعات", "المالية"
  email       String
  phone       String?
}

model ClientOrder {
  id              Int      @id @default(autoincrement())
  clientId        Int
  client          Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  repId           String
  rep             User     @relation("RepOrders", fields: [repId], references: [id])
  status          String   @default("NEW") // NEW, REVIEW, APPROVED, DELIVERING, DELIVERED
  totalAmount     Float    @default(0)
  notes           String?
  rejectionReason String?
  expectedDate    DateTime?
  items           OrderItem[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model OrderItem {
  id         Int         @id @default(autoincrement())
  orderId    Int
  order      ClientOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId  Int
  product    Product     @relation(fields: [productId], references: [id])
  quantity   Int
  unitPrice  Float       @default(0)
  subtotal   Float       @default(0)
}

model WebOrder {
  id              Int            @id @default(autoincrement())
  userId          String?
  user            User?          @relation(fields: [userId], references: [id])
  customerName    String
  customerEmail   String?
  customerPhone   String
  governorate     String
  shippingAddress String
  shippingFee     Float          @default(0)
  paymentMethod   String         @default("COD")
  totalAmount     Float          @default(0)
  status          String         @default("PENDING") // PENDING, PROCESSING, SHIPPED, DELIVERED, CANCELLED
  items           WebOrderItem[]
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  promoCode      String?
  discountAmount Float   @default(0)
  notes          String?
}

model WebOrderItem {
  id         Int      @id @default(autoincrement())
  orderId    Int
  order      WebOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId  Int
  product    Product  @relation(fields: [productId], references: [id])
  quantity   Int
  unitPrice  Float    @default(0)
  subtotal   Float    @default(0)
}

model ShippingZone {
  id        Int      @id @default(autoincrement())
  name_ar   String   @unique
  name_en   String   @unique
  fee       Float    @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PromoCode {
  id             Int       @id @default(autoincrement())
  code           String    @unique
  type           String    // PERCENTAGE or FIXED
  value          Float
  minOrderValue  Float?
  maxUses        Int?
  usedCount      Int       @default(0)
  isActive       Boolean   @default(true)
  expiresAt      DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}
